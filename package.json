{
  "name": "@vitus-labs/tools-root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Pre-configured tooling for development",
  "author": "Vit Bokisch <vit@bokisch.com>",
  "license": "MIT",
  "homepage": "https://github.com/vitus-labs/tools#readme",
  "repository": "git@github.com:vitus-labs/tools.git",
  "bugs": {
    "url": "https://github.com/vitus-labs/tools/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "changeset": "changeset",
    "version-packages": "changeset version && bun install",
    "release": "node scripts/publish.js",
    "pkgs:clean": "rm -rf node_modules/ bun.lock && bun install",
    "pkgs:build": "bun run --filter '*' build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "bun run --filter '*' typecheck",
    "format": "biome format --write .",
    "lint": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "~2.4.16",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitus-labs/tools-lint": "^2.5.0",
    "@vitus-labs/tools-storybook": "workspace:*",
    "react": "^19.2.7",
    "typescript": "6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "packageManager": "bun@1.3.9",
  "dependencies": {
    "next": "^16.2.9"
  },
  "overrides": {
    "shell-quote": ">=1.8.4"
  }
}
