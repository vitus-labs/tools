{
  "name": "@vitus-labs/tools-favicon",
  "version": "2.6.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vitus-labs/tools",
    "directory": "packages/favicon"
  },
  "author": "Vit Bokisch <vit@bokisch.com>",
  "maintainers": [
    "Vit Bokisch <vit@bokisch.com>"
  ],
  "type": "module",
