{
  "name": "@vitus-labs/tools-storybook",
  "version": "2.3.1",
  "license": "MIT",
  "author": "Vit Bokisch <vit@bokisch.com>",
  "maintainers": [
    "Vit Bokisch <vit@bokisch.com>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vitus-labs/tools",
    "directory": "packages/storybook"
  },
  "type": "module",
  "exports": {
    ".": "./lib/config/index.js",
    "./storybook": "./lib/storybook/index.js",
    "./storybook/preview": "./lib/storybook/preview.js",
    "./storybook/main": "./lib/storybook/main.js",
    "./storybook/manager": "./lib/storybook/manager.js"
  },
  "types": "./lib/types/index.d.ts",
  "bin": {
    "vl_stories": "./lib/bin/run-stories.js",
    "vl_stories-build": "./lib/bin/run-stories-build.js",
    "vl_stories-monorepo": "./lib/bin/run-stories-monorepo.js",
    "vl_stories-monorepo-build": "./lib/bin/run-stories-monorepo-build.js"
  },
  "engines": {
    "node": ">= 22"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib/"
  ],
  "scripts": {
    "prepublish": "bun run build",
    "build": "rm -rf lib && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19",
    "react-native": ">=0.74",
    "react-native-web": ">=0.19"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "react-native-web": {
      "optional": true
    }
  },
  "dependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-designs": "^11.1.3",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-themes": "^10.4.0",
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/nextjs-vite": "^10.4.0",
    "@storybook/react": "^10.4.0",
    "@storybook/react-native": "^10.4.4",
    "@storybook/react-vite": "^10.4.0",
    "@vitus-labs/tools-core": "workspace:^",
    "@vueless/storybook-dark-mode": "^10.0.8",
    "storybook": "^10.4.0",
    "storybook-addon-pseudo-states": "^10.4.0",
    "tinyglobby": "^0.2.16",
    "vite": "^8.0.13",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "devDependencies": {
    "@vitus-labs/tools-typescript": "workspace:^",
    "typescript": "^6.0.3"
  }
}
